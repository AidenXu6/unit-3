color red =#FB3640;
color grey=#605F5E;
color pink=#FCBFB7;
color blue=#26547C;
color green=#06D6A0;

void setup (){
  size(800,800);
  
}

void draw(){
  background(grey);
  
  fill(red);
  ellipse(150,75,75,75);
  
  fill(blue);
  ellipse(300,75,75,75);
  
  fill(pink);
  ellipse(500,75,75,75);
  
  fill(green);
  ellipse(650,75,75,75);
}
